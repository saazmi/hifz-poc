{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@hifz/core": ["../../packages/hifz-core/src/index.ts"],
      "@hifz/core/*": ["../../packages/hifz-core/src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"]
}
